---
import LandingLayout from '../layouts/LandingLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<LandingLayout title="My Travels">
  <div class="landing-header">
    <h1>My Travels</h1>
    <p class="tagline">A collection of journeys, itineraries, and memories from around the world.</p>
  </div>

  <div class="divider"></div>

  <p class="section-label">Journeys</p>

  <div class="travel-grid">
    <a href={`${base}/japan2026/`} class="travel-card">
      <div class="card-icon">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 21H21" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M5 21V7L12 3L19 7V21" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M9 10C9 10 10 9 12 9C14 9 15 10 15 10" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>
      <div class="card-content">
        <span class="card-title">Japan</span>
        <span class="card-subtitle">Autumn 2026, 14 Days</span>
      </div>
    </a>
    <a href={`${base}/jersey2026/`} class="travel-card">
      <div class="card-icon">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2V22" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M8 6H16" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M7 10H17" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M9 22C9 18 15 18 15 22" stroke-linecap="round" stroke-linejoin="round" />
          <circle cx="12" cy="13" r="1.5" />
        </svg>
      </div>
      <div class="card-content">
        <span class="card-title">Jersey</span>
        <span class="card-subtitle">May 2026, 4 Days</span>
      </div>
    </a>
    <a href={`${base}/menton2026/`} class="travel-card">
      <div class="card-icon">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 21H21" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M5 21V11L12 5L19 11V21" stroke-linecap="round" stroke-linejoin="round" />
          <circle cx="12" cy="14" r="2" />
          <path d="M12 3V5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>
      <div class="card-content">
        <span class="card-title">Menton</span>
        <span class="card-subtitle">Summer 2026, 9 Days</span>
      </div>
    </a>
  </div>

  <footer class="landing-footer">
    <p>Built with Astro</p>
  </footer>
</LandingLayout>
