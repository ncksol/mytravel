---
import TripLayout from '../../layouts/TripLayout.astro';
import { mentonNavItems } from '../../lib/menton-nav';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const prefix = `${base}/menton2026`;
---

<TripLayout
  title="Overview"
  activeNav="home"
  tripPrefix="/menton2026"
  tripTitle="Menton 2026"
  tripSubtitle="French Riviera"
  tripFooter="menton 2026 · french riviera · 27 jun–5 jul"
  navItems={mentonNavItems(prefix)}
>
  <div class="hero">
    <h1>Menton 2026</h1>
    <p class="subtitle">French Riviera · 27 June – 5 July · a working week with two big free days</p>
  </div>

  <div class="trip-overview">
    <div class="stat-item">
      <div class="stat-value">8</div>
      <div class="stat-label">Nights</div>
    </div>
    <div class="stat-item">
      <div class="stat-value">2</div>
      <div class="stat-label">Countries</div>
    </div>
    <div class="stat-item">
      <div class="stat-value">2</div>
      <div class="stat-label">Travellers</div>
    </div>
    <div class="stat-item">
      <div class="stat-value">2</div>
      <div class="stat-label">Free Days</div>
    </div>
  </div>

  <div class="nav-grid">
    <a href={`${prefix}/itinerary`} class="nav-card">
      <span class="card-emoji">☀</span>
      <span class="card-title">Itinerary</span>
      <span class="card-desc">Day-by-day: Nice arrival, Monaco + Èze, the working week, Ventimiglia + Dolceacqua</span>
    </a>
    <a href={`${prefix}/restaurants`} class="nav-card">
      <span class="card-emoji">🍽</span>
      <span class="card-title">Restaurants</span>
      <span class="card-desc">L'Orangerie splurge, Castelroc & Casa e Bottega lunches, the 5-night rotation</span>
    </a>
    <a href={`${prefix}/sights`} class="nav-card">
      <span class="card-emoji">🌿</span>
      <span class="card-title">Sights</span>
      <span class="card-desc">Cocteau, the gardens, Monaco's Rock, Èze, Dolceacqua's Monet bridge — plus daily swims</span>
    </a>
    <a href={`${prefix}/bookings`} class="nav-card">
      <span class="card-emoji">✉</span>
      <span class="card-title">Bookings</span>
      <span class="card-desc">Luggage drop + five food reservations + day-of re-checks</span>
    </a>
    <a href={`${prefix}/practical-info`} class="nav-card">
      <span class="card-emoji">✦</span>
      <span class="card-title">Practical Info</span>
      <span class="card-desc">Trains, buses, beaches, money, and the Saint-Pierre festival on your dates</span>
    </a>
  </div>
</TripLayout>
